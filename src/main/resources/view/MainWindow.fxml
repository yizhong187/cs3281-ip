<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane minHeight="400.0" minWidth="380.0"
            prefHeight="620.0" prefWidth="420.0"
            style="-fx-background-color: #f0f2f5;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="aria.ui.MainWindow">
    <children>

        <!-- Header bar -->
        <HBox alignment="CENTER_LEFT" prefHeight="52.0" spacing="8.0"
              style="-fx-background-color: #2c3e50;"
              AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <padding><Insets left="16.0" right="16.0"/></padding>
            <Label text="Aria" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
            <Label text="task manager" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12; -fx-padding: 4 0 0 4;"/>
        </HBox>

        <!-- Chat scroll area -->
        <ScrollPane fx:id="scrollPane" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    fitToWidth="true" vvalue="1.0"
                    style="-fx-background: #f0f2f5; -fx-background-color: transparent; -fx-border-color: transparent;"
                    AnchorPane.topAnchor="52.0" AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="56.0">
            <content>
                <VBox fx:id="dialogContainer" spacing="8.0"
                      style="-fx-background-color: #f0f2f5;">
                    <padding><Insets top="12.0" bottom="12.0" left="0.0" right="0.0"/></padding>
                </VBox>
            </content>
        </ScrollPane>

        <!-- Input bar -->
        <HBox alignment="CENTER" spacing="0.0"
              style="-fx-background-color: #ffffff; -fx-border-color: #dde1e7; -fx-border-width: 1 0 0 0;"
              prefHeight="56.0"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <padding><Insets left="12.0" right="0.0"/></padding>
            <TextField fx:id="userInput" onAction="#handleUserInput"
                       promptText="Type a command..."
                       style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 14;"
                       HBox.hgrow="ALWAYS"/>
            <Button fx:id="sendButton" mnemonicParsing="false" onAction="#handleUserInput"
                    text="Send" prefHeight="56.0" prefWidth="80.0"
                    style="-fx-background-color: #5b8dee; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 0; -fx-cursor: hand; -fx-font-size: 14;"/>
        </HBox>

    </children>
</AnchorPane>
