<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane minHeight="400.0" minWidth="380.0"
            prefHeight="600.0" prefWidth="400.0" style="-fx-background-color: #f5f5f5;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="MainWindow">
    <children>
        <TextField fx:id="userInput" onAction="#handleUserInput"
                   prefHeight="41.0" promptText="Type a message..."
                   style="-fx-background-radius: 0; -fx-border-color: #ddd; -fx-border-width: 1 0 0 0;"
                   AnchorPane.bottomAnchor="1.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="76.0"/>
        <Button fx:id="sendButton" mnemonicParsing="false" onAction="#handleUserInput"
                prefHeight="41.0" prefWidth="76.0" text="Send"
                style="-fx-background-color: #5b8dee; -fx-text-fill: white; -fx-background-radius: 0; -fx-cursor: hand;"
                AnchorPane.bottomAnchor="1.0" AnchorPane.rightAnchor="0.0"/>
        <ScrollPane fx:id="scrollPane" hbarPolicy="NEVER" hvalue="1.0" vvalue="1.0"
                    style="-fx-background: #f5f5f5; -fx-background-color: #f5f5f5;"
                    AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="42.0">
            <content>
                <VBox fx:id="dialogContainer"
                      style="-fx-background-color: #f5f5f5;"/>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
